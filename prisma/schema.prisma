generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth / Identity ─────────────────────────────────────────────────────────

// Mirrors auth.users from Supabase. id = Supabase auth UUID.
model UserProfile {
  id             String        @id               // matches auth.users.id
  role           Role          @default(CLIENT)
  name           String?
  email          String?       @unique
  // For CLIENT accounts: which practitioner invited them
  practitionerId String?
  practitioner   UserProfile?  @relation("PractitionerClients", fields: [practitionerId], references: [id])
  clients        UserProfile[] @relation("PractitionerClients")
  threads        Thread[]
  thoughts       ThoughtEntry[]
  createdAt      DateTime      @default(now())
}

enum Role {
  PRACTITIONER
  CLIENT
}

// ─── Legacy anonymous tracking (kept for backward compat) ─────────────────────

model Visitor {
  id        String    @id @default(uuid())
  firstSeen DateTime  @default(now())
  sessions  Session[]
  threads   Thread[]
  thoughts  ThoughtEntry[]
}

model Session {
  id        String       @id @default(uuid())
  visitorId String
  visitor   Visitor      @relation(fields: [visitorId], references: [id])
  threads   Thread[]
  thoughts  ThoughtEntry[]
  createdAt DateTime     @default(now())
}

// ─── Core domain ──────────────────────────────────────────────────────────────

model Thread {
  id        String        @id @default(uuid())
  sessionId String
  visitorId String
  userId    String?       // authenticated user (null for anonymous)
  title     String?
  situation String?
  session   Session       @relation(fields: [sessionId], references: [id])
  visitor   Visitor       @relation(fields: [visitorId], references: [id])
  user      UserProfile?  @relation(fields: [userId], references: [id])
  thoughts  ThoughtEntry[]
  insight   ThreadInsight?
  createdAt DateTime      @default(now())

  @@index([userId])
}

model ThoughtEntry {
  id                 String    @id @default(uuid())
  threadId           String?
  sessionId          String?
  visitorId          String?
  userId             String?   // authenticated user (null for anonymous)
  thought            String
  intent             String   @default("THOUGHT")
  status             String   @default("REFLECTION_COMPLETE")
  situation          String?
  automaticThought   String?
  story              String
  emotion            String
  coreBelief         String?
  reflectionQuestion String
  balancedThought    String
  pattern            String?
  patternExplanation String?
  normalization      String?
  createdAt          DateTime  @default(now())

  thread   Thread?      @relation(fields: [threadId], references: [id])
  session  Session?     @relation(fields: [sessionId], references: [id])
  visitor  Visitor?     @relation(fields: [visitorId], references: [id])
  user     UserProfile? @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@index([userId])
}

model ThreadInsight {
  id              String   @id @default(uuid())
  threadId        String   @unique
  dominantPattern String?
  dominantEmotion String?
  dominantBelief  String?
  thoughtCount    Int      @default(0)
  thread          Thread   @relation(fields: [threadId], references: [id])
  updatedAt       DateTime @updatedAt
}
