generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model ThoughtEntry {
  id                 String   @id @default(uuid())
  thought            String
  fact               String
  story              String
  emotion            String
  reflectionQuestion String
  balancedThought    String
  createdAt          DateTime @default(now())

  @@index([createdAt])
}